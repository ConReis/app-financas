# ============================================================
# FinançasPessoais — Variáveis de Ambiente
# ============================================================
# ATENÇÃO: Nunca comite o arquivo .env.local com valores reais.
#          Use este arquivo apenas como referência.
#
# Para desenvolvimento local:
#   cp env.template .env.local
#   Preencha os valores abaixo e salve como .env.local
#
# Para Vercel (produção):
#   Configure estas variáveis em:
#   Vercel Dashboard → seu projeto → Settings → Environment Variables
# ============================================================

# Supabase — obtenha em: supabase.com → seu projeto → Settings → API
#
# SEGURANÇA:
#   NEXT_PUBLIC_* são variáveis públicas (vão para o browser).
#   A anon key do Supabase é uma "publishable key" — projetada para
#   ser pública. A segurança real está nas políticas RLS do banco.
#   NUNCA exponha a "service_role key" com prefixo NEXT_PUBLIC_.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_SUA_CHAVE_AQUI
